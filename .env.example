# ==============================================================================
# Sea King Capital — environment variables template
# Copy to apps/manager/.env.local and apps/client-portal/.env.local, fill in.
# NEVER commit .env.local files.
# ==============================================================================

# ----- Supabase (shared by both apps) -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only. Bypasses RLS. Used by server actions that legitimately need
# elevated access (e.g., inserting ledger_events from a background job).
# MUST only be read server-side; never expose in the client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

SUPABASE_PROJECT_REF=ucfyfnwkxzryywuomool

# ----- Resend (email) — Phase 1H -----
RESEND_API_KEY=

# ----- App URLs (for absolute links in emails) -----
NEXT_PUBLIC_MANAGER_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLIENT_PORTAL_URL=http://localhost:3001

# ----- Notification sink addresses -----
OVERADVANCED_EMAIL=overadvanced@seakingcapital.com
ADVANCE_REQUEST_EMAIL=advancerequest@seakingcapital.com
