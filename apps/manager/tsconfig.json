{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@seaking/money": ["../../packages/money/src/index.ts"],
      "@seaking/money/*": ["../../packages/money/src/*"],
      "@seaking/dates": ["../../packages/dates/src/index.ts"],
      "@seaking/dates/*": ["../../packages/dates/src/*"],
      "@seaking/validators": ["../../packages/validators/src/index.ts"],
      "@seaking/validators/*": ["../../packages/validators/src/*"],
      "@seaking/db": ["../../packages/db/src/index.ts"],
      "@seaking/db/*": ["../../packages/db/src/*"],
      "@seaking/auth": ["../../packages/auth/src/index.ts"],
      "@seaking/auth/*": ["../../packages/auth/src/*"],
      "@seaking/ui": ["../../packages/ui/src/index.ts"],
      "@seaking/ui/*": ["../../packages/ui/src/*"],
      "@seaking/api": ["../../packages/api/src/index.ts"],
      "@seaking/api/*": ["../../packages/api/src/*"],
      "@seaking/retailer-parsers": ["../../packages/retailer-parsers/src/index.ts"],
      "@seaking/retailer-parsers/*": ["../../packages/retailer-parsers/src/*"]
    },
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "allowJs": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "Bundler",
    "skipLibCheck": true
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
